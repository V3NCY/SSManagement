<Window x:Class="EmployeeDocumentManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Management App" Height="350" Width="725">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Employee Management Application" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <UniformGrid Rows="1" Columns="3" Margin="0,0,0,10">
                <Button Content="Отпуски" Click="OnLeaveRequestsButtonClick" Width="150" Height="30"/>
                <Button Content="Болничи" Click="OnSickLeaveButtonClick" Width="150" Height="30"/>
                <Button Content="Молби" Click="OnSpecialRequestsButtonClick" Width="150" Height="30" Margin="10"/>
                <Button Content="Добави служител" Click="OnEmployeeRegistrationButtonClick" Width="150" Height="30" Margin="10"/>
                <Button Content="Списък със служители" Click="OnViewEmployeeListButtonClick" Width="150" Height="30"/>

            </UniformGrid>

            <Frame x:Name="mainFrame" NavigationUIVisibility="Hidden"/>
        </StackPanel>
    </Grid>
</Window>
