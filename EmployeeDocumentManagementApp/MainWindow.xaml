<Window x:Class="EmployeeDocumentManagementApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Management App" Height="350" Width="525">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Employee Management App" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <UniformGrid Rows="1" Columns="2" Margin="0,0,0,10">
                <Button Content="Отпуски" Click="OnLeaveRequestsButtonClick" Width="150" Height="30"/>
                <Button Content="Болничи" Click="OnSickLeaveButtonClick" Width="150" Height="30"/>
                <Button Content="Молби" Click="OnSickLeaveButtonClick" Width="150" Height="30" Margin="10"/>
                <!-- Add more buttons for other features or sections as needed -->
            </UniformGrid>

            <Frame x:Name="mainFrame" NavigationUIVisibility="Hidden"/>
        </StackPanel>
    </Grid>
</Window>
